# Google Maps API 키
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# API 키 사용시 주의사항:
# 1. Google Cloud Console에서 다음 제한사항을 설정하세요:
# - HTTP 리퍼러 제한 (도메인 기반)
# - IP 주소 제한
# - API 사용량 쿼터 설정
# 2. 실제 API 키는 절대 이 파일에 입력하지 마세요. .env.local 파일을 사용하세요.

# Google Gemini API Key for AI Analysis
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here 