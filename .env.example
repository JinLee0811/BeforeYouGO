# Google Maps API (JS is loaded per-page via @react-google-maps/api useLoadScript)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here
GOOGLE_MAPS_PLACES_DETAILS_URL=https://maps.googleapis.com/maps/api/place/details/json
GOOGLE_MAPS_PHOTO_URL=https://maps.googleapis.com/maps/api/place/photo

# AI — Pro 분석(/api/analyze). 기본: OPENAI_API_KEY 가 있으면 OpenAI(gpt-4o-mini), 없으면 Anthropic, 그다음 Gemini.
OPENAI_API_KEY=sk-your-openai-key
# json_object 지원 모델 권장: gpt-4o-mini, gpt-4o, gpt-4-turbo 등
OPENAI_MODEL=gpt-4o-mini

# 선택: anthropic | openai | gemini. 비우면 위 우선순위로 자동.
# LLM_PROVIDER=openai

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# AI에 넣을 Google 리뷰 최대 개수 (토큰·비용, 기본 5, 상한 20). Places는 보통 최대 5개만 제공.
MAX_REVIEWS_FOR_ANALYSIS=5

# 동일 식당(place_id) 요약 캐시 유효 일수. 이내면 Supabase summaries 만 반환(LLM/Places 스킵). 기본 7, 1~365.
SUMMARY_CACHE_TTL_DAYS=7

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# 서버 API 전용(절대 클라이언트에 넣지 말 것). 없으면 쿼터는 사용자 JWT로 DB 접근(RLS 필요).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 로컬 시연만: next dev 에서 분석 쿼터 DB(user_api_usage) 건너뛰기 (production 에서는 무시됨)
# DEMO_SKIP_ANALYSIS_QUOTA=true

# 쿼터 읽기/업데이트 실패 시에도 요청을 통과시킴(로그만 남김). 테이블 미생성·RLS 디버깅용. 운영에서는 비활성 권장.
# QUOTA_FAIL_OPEN=true

# 일일 무료 분석 횟수(자정마다 갱신). 기본 5. 날짜 기준: 비우면 UTC 자정, 한국이면 Asia/Seoul
# ANALYSIS_USAGE_LIMIT=5
# ANALYSIS_QUOTA_TIMEZONE=Asia/Seoul

# 분석 쿼터 면제(서버만). 쉼표로 여러 값. 이메일은 Supabase Auth 이메일과 대소문자 무관 매칭.
# DB 방식: profiles.is_analysis_admin = true (마이그레이션 20260403120000) 로도 동일 효과 — env 불필요.
# ANALYSIS_ADMIN_EMAILS=you@example.com,other@example.com
# ANALYSIS_ADMIN_USER_IDS=uuid-from-auth-users-one,uuid-two

# 사용자당 분석 허용 횟수(기본 3). 어드민은 위 변수로 무제한.
# ANALYSIS_USAGE_LIMIT=3

# Supabase Auth redirect URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_REDIRECT_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_EMAIL_REDIRECT_URL=http://localhost:3000

# Stripe (optional)
STRIPE_PUBLIC_KEY=your_publishable_key
STRIPE_SECRET_KEY=your_secret_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret
